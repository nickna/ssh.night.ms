# Copy to deploy/.env and fill in. Do NOT commit the resulting deploy/.env.
# Compose reads this when invoked as
#   docker compose -f deploy/compose.yml --env-file deploy/.env up -d
#
# Migrating from the .NET stack: keep POSTGRES_PASSWORD identical to the
# existing value (otherwise the nightms_pg-data volume won't open). The Go
# stack accepts the existing NIGHTMS_WEB_BASE_URL value unchanged.

# --- REQUIRED -----------------------------------------------------------------

POSTGRES_PASSWORD=changeme-strong-postgres-pw

# --- Optional but recommended -------------------------------------------------

# Cookie signing key. When unset the app generates 32 bytes on first boot and
# persists them to /data/host-keys/cookie-secret (mode 0600); the key then
# survives restarts and image updates. Set this only when you need to lift a
# specific key (e.g. coordinating across replicas). Generate with:
#   openssl rand -hex 32
NIGHTMS_COOKIE_SECRET=

# Bootstrap sysop on first boot. Safe to leave set across reboots — the
# bootstrap step is idempotent and only promotes an existing handle.
NIGHTMS_BOOTSTRAP_SYSOP_HANDLE=
NIGHTMS_BOOTSTRAP_SYSOP_PASSWORD=

# Externally-visible web origin. Accepts either a bare host ("night.ms") or
# a full URL ("https://night.ms") — the app parses out the host either way,
# so values inherited from the .NET stack work unchanged.
NIGHTMS_WEB_BASE_URL=https://night.ms

# Host advertised in the "ssh -p 2222 you@<host>" snippets on the landing,
# login, and profile pages. Set this when the SSH listener and the HTTP
# listener live on different names — e.g. SSH direct at ssh.night.ms while
# HTTP runs behind Cloudflare at k.night.ms. Falls back to NIGHTMS_WEB_BASE_URL
# when unset, which is correct for single-host deployments.
NIGHTMS_SSH_HOST=

# External SSH port shown in those same snippets. The compose stack binds
# container :2222 to host :22, so prod should advertise port 22. The app
# drops the "-p" flag when this is "22" (the SSH default), so the page
# renders "ssh you@host". Leave unset for dev — falls back to the bind
# port (2222 by default).
NIGHTMS_SSH_PORT=22
