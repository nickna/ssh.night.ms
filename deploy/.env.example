# Copy to deploy/.env on the VPS and fill in. Compose reads this when invoked as
# `docker compose -f deploy/compose.yml --env-file deploy/.env up -d`.
#
# Everything not marked REQUIRED can be left blank.

# --- REQUIRED -----------------------------------------------------------------

# Postgres password (the bbs user is created with this on first boot — change
# before bringing the stack up the first time, or you're stuck with the default).
POSTGRES_PASSWORD=change-me-to-a-real-password

# --- Optional but recommended -------------------------------------------------

# Handle promoted to sysop on first registration (or at every startup if the user
# already exists). Leave blank if you want to do it via SQL later.
NIGHTMS_BOOTSTRAP_SYSOP_HANDLE=nick

# Externally-visible web origin (used to build the "upload your picture at …"
# hint in the TUI). Display only — not used in the auth flow.
NIGHTMS_WEB_BASE_URL=https://k.night.ms

# Externally-visible SSH host + port (used to build the "ssh <handle>@…" hints
# on the web pages). NIGHTMS_SSH_PORT_PUBLIC defaults to BBS_SSH_PORT; set it
# when a port mapping or NAT rule fronts the listener (e.g. the compose stack
# binds host :22 → container :2222, so the public-facing port is 22).
NIGHTMS_SSH_HOST=ssh.night.ms
NIGHTMS_SSH_PORT_PUBLIC=22

# Default log level: Information / Warning / Debug
LOG_LEVEL=Information

# --- Google + Microsoft SSO (optional) ----------------------------------------
# When both ID + secret are set for a provider, the "Sign in with X" button
# appears on /login. When unset, the provider is silently disabled.
#
# Redirect URIs to register at the provider:
#   https://k.night.ms/signin-google
#   https://k.night.ms/signin-microsoft

NIGHTMS_GOOGLE_CLIENT_ID=
NIGHTMS_GOOGLE_CLIENT_SECRET=
NIGHTMS_MICROSOFT_CLIENT_ID=
NIGHTMS_MICROSOFT_CLIENT_SECRET=
