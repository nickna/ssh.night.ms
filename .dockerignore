# Build output
**/bin/
**/obj/
**/out/
**/publish/

# IDE + editor
.vs/
.vscode/
.idea/
*.user
*.suo

# OS
.DS_Store
Thumbs.db

# Local dev state — never bake into the image
data/
.run-*.log

# Workspaces + agent dirs
.claude/

# Tests aren't published; skip them in the build context to keep it small
tests/

# Git
.git/
.gitignore
.gitattributes

# Docs (the build doesn't need them)
*.md
