{{define "body"}}
<section class="auth">
  <h1>change password</h1>
  {{if .Error}}<p class="error">{{.Error}}</p>{{end}}
  <form method="post" action="/profile/password" autocomplete="on">
    {{.CSRFField}}
    <label>current password <input type="password" name="current" required></label>
    <label>new password <input type="password" name="new" minlength="10" required></label>
    <label>confirm new <input type="password" name="confirm" minlength="10" required></label>
    <button type="submit">update</button>
  </form>
  <p class="muted"><a href="/profile">back to profile</a></p>
</section>
{{end}}
