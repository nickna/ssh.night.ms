{{define "body"}}
<section class="auth">
  <h1>finish signup</h1>
  {{with .OAuthFinish}}
  <p class="muted">signed in with {{.Provider}} as {{.Email}}. pick a handle to finish creating your account.</p>
  {{if $.Error}}<p class="error">{{$.Error}}</p>{{end}}
  <form method="post" action="/auth/finish" autocomplete="off">
    {{$.CSRFField}}
    <label>handle
      <input type="text" name="handle" value="{{.SuggestedHandle}}"
        autocapitalize="off" autocorrect="off" spellcheck="false" required
        pattern="[A-Za-z0-9_-]{3,32}"
        title="3-32 chars: letters, digits, underscore, dash">
    </label>
    <button type="submit">create account</button>
  </form>
  <p class="muted">3-32 chars: letters, digits, underscore, dash.</p>
  {{else}}
  <p class="muted">session expired — <a href="/login">start over</a>.</p>
  {{end}}
</section>
{{end}}
