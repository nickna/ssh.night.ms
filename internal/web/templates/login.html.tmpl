{{define "body"}}
<section class="auth">
  <h1>log in</h1>
  {{if .Error}}<p class="error">{{.Error}}</p>{{end}}
  <form method="post" action="/login" autocomplete="on">
    {{.CSRFField}}
    <label>handle <input type="text" name="handle" autocapitalize="off" autocorrect="off" spellcheck="false" required></label>
    <label>password <input type="password" name="password" required></label>
    <button type="submit">log in</button>
  </form>
  <p class="muted">no account yet? connect via ssh first: <code>{{.SSHCmd}} yourhandle@{{.Host}}</code></p>
</section>
{{end}}
