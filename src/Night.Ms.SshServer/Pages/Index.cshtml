@page "/"
@model IndexModel
@{
    ViewData["Title"] = "ssh.night.ms";
}

<h1>ssh.night.ms</h1>
<p class="muted">A small BBS that lives over SSH.</p>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="box">
        <h2>Welcome back, @User.Identity.Name</h2>
        <p>Jump straight in:</p>
        <div class="actions">
            <a href="/terminal" class="btn">Open web terminal</a>
            <a href="/profile" class="btn">Profile</a>
        </div>
    </div>
}

<div class="box">
    <h2>Connect from your terminal</h2>
    @if (Model.SshPort == 22)
    {
        <pre>ssh &lt;handle&gt;@@@Model.SshHost</pre>
    }
    else
    {
        <pre>ssh -p @Model.SshPort &lt;handle&gt;@@@Model.SshHost</pre>
    }
    <p class="muted">
        First connection from a new key drops you into the registration screen — pick a handle
        and you're in. There's no email recovery; lose the key, lose the account.
    </p>
</div>

@if (Model.AnySsoConfigured)
{
    <div class="box">
        <h2>Sign in to the web</h2>
        <p>Manage your linked identities, see your profile, and (soon) connect to the BBS from the browser.</p>
        <div class="actions">
            @if (Model.GoogleConfigured)
            {
                <form method="post" action="/login/google" class="inline">@Html.AntiForgeryToken()<button class="btn">Sign in with Google</button></form>
            }
            @if (Model.MicrosoftConfigured)
            {
                <form method="post" action="/login/microsoft" class="inline">@Html.AntiForgeryToken()<button class="btn">Sign in with Microsoft</button></form>
            }
        </div>
    </div>
}
