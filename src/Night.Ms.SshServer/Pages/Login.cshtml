@page "/login"
@model LoginModel
@{
    ViewData["Title"] = "sign in — ssh.night.ms";
}

<h1>Sign in</h1>

@if (Model.Flash is not null)
{
    <div class="box flash"><p>@Model.Flash</p></div>
}

<h2>Sign in with handle &amp; password</h2>
<form method="post" action="/login/password" class="box">
    @Html.AntiForgeryToken()
    <p>Handle: <input type="text" name="handle" required autocomplete="username" /></p>
    <p>Password: <input type="password" name="password" required autocomplete="current-password" /></p>
    <button class="btn" type="submit">Sign in</button>
</form>
<p class="muted">
    Accounts that require an SSH key for login can't sign in here. Open an SSH session and use
    <strong>Profile &rarr; Open in browser</strong> to get a one-time link instead.
</p>

@if (Model.AnySsoConfigured)
{
    <h2>Or sign in with a linked SSO provider</h2>
    <div class="actions">
        @if (Model.GoogleConfigured)
        {
            <form method="post" action="/login/google" class="inline">@Html.AntiForgeryToken()<button class="btn">Sign in with Google</button></form>
        }
        @if (Model.MicrosoftConfigured)
        {
            <form method="post" action="/login/microsoft" class="inline">@Html.AntiForgeryToken()<button class="btn">Sign in with Microsoft</button></form>
        }
    </div>
    <p class="muted">
        Already on the BBS? Sign in here and you can link this account to your SSH identity from
        the profile screen.
    </p>
}
