@page "/terminal"
@model TerminalModel
@{
    ViewData["Title"] = "terminal — ssh.night.ms";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/xterm/xterm.min.css" />
    <style>
        html, body { margin: 0; padding: 0; height: 100%; background: #0a0e0f; color: #d4d7d6; font-family: ui-monospace, "JetBrains Mono", "SF Mono", Menlo, Consolas, monospace; }
        #topbar { display: flex; align-items: center; justify-content: space-between; padding: 6px 14px; border-bottom: 1px solid #1f2a2a; font-size: 13px; }
        #topbar a { color: #5fb3a1; text-decoration: none; }
        #topbar a:hover { text-decoration: underline; }
        #status { color: #6b7472; }
        #term { position: absolute; top: 38px; left: 0; right: 0; bottom: 0; padding: 8px; }
        .xterm .xterm-viewport { background: #0a0e0f !important; }
    </style>
</head>
<body>
    <div id="topbar">
        <span><a href="/">ssh.night.ms</a> &middot; @User.Identity!.Name</span>
        <span id="status">connecting&hellip;</span>
    </div>
    <div id="term"></div>

    <script src="~/lib/xterm/xterm.min.js"></script>
    <script src="~/lib/xterm/addon-fit.min.js"></script>
    <script>
        (function () {
            const status = document.getElementById("status");
            const setStatus = (text, color) => { status.textContent = text; status.style.color = color || "#6b7472"; };

            const term = new Terminal({
                fontFamily: 'ui-monospace, "JetBrains Mono", "SF Mono", Menlo, Consolas, monospace',
                fontSize: 14,
                cursorBlink: true,
                allowProposedApi: true,
                convertEol: false,
                theme: {
                    background: "#0a0e0f",
                    foreground: "#d4d7d6",
                    cursor:    "#5fb3a1",
                    selectionBackground: "#1f2a2a",
                },
            });
            const fit = new FitAddon.FitAddon();
            term.loadAddon(fit);
            term.open(document.getElementById("term"));
            fit.fit();

            const wsProto = location.protocol === "https:" ? "wss:" : "ws:";
            const ws = new WebSocket(wsProto + "//" + location.host + "/ws/bbs");
            ws.binaryType = "arraybuffer";

            const encoder = new TextEncoder();
            const sendResize = () => {
                if (ws.readyState !== WebSocket.OPEN) return;
                ws.send(JSON.stringify({ type: "resize", cols: term.cols, rows: term.rows }));
            };

            ws.addEventListener("open", () => {
                setStatus("connected", "#5fb3a1");
                sendResize();
            });
            ws.addEventListener("close", e => {
                setStatus("disconnected" + (e.reason ? " (" + e.reason + ")" : ""), "#d49a5f");
                term.write("\r\n\x1b[33m[disconnected]\x1b[0m\r\n");
            });
            ws.addEventListener("error", () => setStatus("error", "#d46e6e"));
            ws.addEventListener("message", e => {
                if (typeof e.data === "string") return;     // ignore stray control frames
                term.write(new Uint8Array(e.data));
            });

            term.onData(s => {
                if (ws.readyState !== WebSocket.OPEN) return;
                ws.send(encoder.encode(s));
            });

            // FitAddon re-measures on viewport resize; debounce so a drag doesn't flood the wire.
            let resizeTimer = null;
            window.addEventListener("resize", () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(() => { fit.fit(); sendResize(); }, 80);
            });
        })();
    </script>
</body>
</html>
