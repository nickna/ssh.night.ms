@page "/u/{handle}"
@model Night.Ms.SshServer.Pages.U.ProfileModel
@{
    ViewData["Title"] = $"{Model.Handle} — ssh.night.ms";
}

<div class="avatar-row">
    <img class="avatar" src="/u/@Model.Handle/avatar?v=@Model.AvatarVersion" alt="@Model.Handle's avatar" width="96" height="96" />
    <div class="avatar-meta">
        <h1>@Model.Handle @if (Model.IsSysop) { <span class="muted">(sysop)</span> }</h1>
        @if (!string.IsNullOrEmpty(Model.Location))
        {
            <p class="muted">@Model.Location</p>
        }
        @if (!string.IsNullOrEmpty(Model.RealName))
        {
            <p>@Model.RealName</p>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Bio))
{
    <div class="box">
        <p>@Model.Bio</p>
    </div>
}

<table>
    <tbody>
        <tr><th>joined</th><td>@Model.CreatedAt.ToString("yyyy-MM-dd")</td></tr>
        <tr><th>last seen</th><td>@(Model.LastSeenAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "—")</td></tr>
        <tr><th>stats</th><td>@Model.ChatMessageCount chat · @Model.TopicCount topics · @Model.PostCount posts</td></tr>
    </tbody>
</table>

<p class="muted">Connect over SSH: <code>ssh -p 2222 @Model.Handle@@@Model.PublicHost</code></p>
